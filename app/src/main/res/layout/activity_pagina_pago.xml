<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#515151"
    tools:context=".FormularioActivity">

    <!-- Franja superior con imagen oscurecida -->
    <ImageView
        android:id="@+id/ivHeaderBg"
        android:layout_width="0dp"
        android:layout_height="96dp"
        android:alpha="0.22"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_header_gym"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tvTituloFormulario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="40dp"
        android:includeFontPadding="false"
        android:text="Formulario"
        android:textColor="#EFDE1F"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/profileContainer"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="38dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_profile_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivPerfil"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_profile"
            android:tint="#515151"
            tools:ignore="ContentDescription" />
    </FrameLayout>

    <!-- CONTENEDOR EXTERIOR -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardExterior"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#D9D9D9"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloFormulario">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingTop="12dp"
            android:paddingEnd="8dp"
            android:paddingBottom="10dp">

            <!-- CONTENEDOR INTERIOR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFormulario"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#818181"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:layout_constraintBottom_toTopOf="@id/btnFinalizarCompra"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="34dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="18dp">

                    <ImageView
                        android:id="@+id/ivDocumento"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/icono_formulario_3"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:id="@+id/tvNomTitular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="26dp"
                        android:includeFontPadding="false"
                        android:text="Nom titular"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etNomTitular"
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_small"
                        android:ems="10"
                        android:gravity="center_vertical"
                        android:hint="Value"
                        android:importantForAutofill="no"
                        android:includeFontPadding="false"
                        android:inputType="textPersonName"
                        android:minHeight="0dp"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:textColor="#111111"
                        android:textColorHint="#B8B8B8"
                        android:textSize="6sp" />

                    <TextView
                        android:id="@+id/tvNumeroTarjeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:includeFontPadding="false"
                        android:text="Numero de targeta"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etNumeroTarjeta"
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_small"
                        android:ems="10"
                        android:gravity="center_vertical"
                        android:hint="Value"
                        android:importantForAutofill="no"
                        android:includeFontPadding="false"
                        android:inputType="number"
                        android:minHeight="0dp"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:textColor="#111111"
                        android:textColorHint="#B8B8B8"
                        android:textSize="6sp" />

                    <TextView
                        android:id="@+id/tvNumeroSecret"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:includeFontPadding="false"
                        android:text="Numero secret"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etNumeroSecret"
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_small"
                        android:ems="10"
                        android:gravity="center_vertical"
                        android:hint="Value"
                        android:importantForAutofill="no"
                        android:includeFontPadding="false"
                        android:inputType="numberPassword"
                        android:minHeight="0dp"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:textColor="#111111"
                        android:textColorHint="#B8B8B8"
                        android:textSize="6sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnFinalizarCompra"
                android:layout_width="178dp"
                android:layout_height="28dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#FFC107"
                android:elevation="0dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="Finalizar compra"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:background="#D9D9D9"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_home"
                android:tint="#111111"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Inici"
                android:textColor="#111111"
                android:textSize="6sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_classes"
                android:tint="#111111"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Classes"
                android:textColor="#111111"
                android:textSize="6sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_store"
                android:tint="#111111"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Tenda"
                android:textColor="#111111"
                android:textSize="6sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_notifications"
                android:tint="#111111"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Notícies"
                android:textColor="#111111"
                android:textSize="6sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_calendar"
                android:tint="#111111"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Calendari"
                android:textColor="#111111"
                android:textSize="6sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_contact"
                android:tint="#111111"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Contacte"
                android:textColor="#111111"
                android:textSize="6sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>