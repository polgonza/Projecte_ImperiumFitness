                android:layout_height="118dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#8E8E8E"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">

                <!--
                    TOT EL PRODUCTE ÉS CLICABLE
                    Posem tag per identificar quin producte s'ha clicat.
                    Després a Kotlin pots llegir view.tag.
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="18dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:onClick="openProductDetail"
                    android:tag="product_1">

                    <!--
                        IMATGE DEL PRODUCTE
                        CANVIA aquest drawable pel nom real de la imatge.
                        Exemple: @drawable/proteina_whey
                    -->
                    <ImageButton
                        android:id="@+id/btnProductImage1"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_marginEnd="14dp"
                        android:background="@android:color/transparent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_product_1"
                        android:contentDescription="Producte 1"
                        android:onClick="openProductDetail"
                        android:tag="product_1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Proteïna"
                            android:textColor="#F5F5F5"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="39,99€"
                            android:textColor="#F5F5F5"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
