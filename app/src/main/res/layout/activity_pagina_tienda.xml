<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D9D9"
    tools:context=".StoreActivity">

    <!--
        CAPÇALERA SUPERIOR
        Aquesta barra queda fixa a dalt.
        Té el títol de la botiga i la icona de perfil a la dreta.
    -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:background="#555555"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStoreTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="La Imperial Store"
            android:textColor="#F0DB1A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!--
            ICONA DE PERFIL / USUARI
            CANVIA aquest drawable pel teu logo o icona real.
            Exemple: @drawable/ic_user_profile
        -->
        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="Perfil"
            android:src="@drawable/ic_profile_placeholder" />
    </LinearLayout>

    <!--
        ZONA CENTRAL DESPLAÇABLE
        IMPORTANT:
        - Només aquesta part fa scroll.
        - El footer i la capçalera es queden fixes.
    -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProducts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            CONTENIDOR DELS PRODUCTES
            Aquí posem els 10 productes un sota l'altre.
